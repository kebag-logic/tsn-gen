{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kebag-logic.com/tsn-gen/protocol.schema.json",
  "title": "tsn-gen protocol definition",
  "description": "One YAML file describes one protocol layer (service). This schema is the formal contract enforced by `packet_gen --validate`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["service"],
  "anyOf": [
    { "required": ["vars"] },
    { "required": ["entities"] }
  ],
  "properties": {
    "service": {
      "type": "string",
      "minLength": 1,
      "description": "Namespace prefix for every var and interface in this file."
    },
    "logic": {
      "type": "string",
      "minLength": 1,
      "description": "Name of a C++ logic module (registered via REGISTER_LOGIC) bound to this service during the stack runtime."
    },
    "vars": {
      "type": "array",
      "items": { "$ref": "#/$defs/var" },
      "description": "Field dictionary: each entry is one fixed-width field."
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" },
      "description": "Entities group the interfaces that select and order vars into PDUs."
    }
  },
  "$defs": {
    "var": {
      "type": "object",
      "additionalProperties": false,
      "required": ["var", "size"],
      "properties": {
        "var": { "type": "string", "minLength": 1 },
        "size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096,
          "description": "Field width in bits. Fields wider than 64 bits (e.g. AVDECC strings) carry the generated value in their low 64 bits; higher bits are zero."
        },
        "expected": { "$ref": "#/$defs/expected" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "At most one constraint form is meaningful; value/values pick from a set, range is inclusive, mask restricts random bits.",
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 0,
          "description": "A single fixed value."
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0 },
          "description": "Exhaustive list of allowed values."
        },
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 },
          "description": "[min, max], inclusive."
        },
        "mask": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "type": "integer", "minimum": 0 },
          "description": "[M]: only bits within M may be set."
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity", "interfaces"],
      "properties": {
        "entity": { "type": "string", "minLength": 1 },
        "interfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/interface" }
        }
      }
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interface", "dir"],
      "properties": {
        "interface": { "type": "string", "minLength": 1 },
        "dir": {
          "type": "string",
          "enum": ["in", "out"],
          "description": "Direction from the entity's perspective."
        },
        "vars": {
          "type": "array",
          "items": { "$ref": "#/$defs/var_ref" },
          "description": "Ordered field references packed into this interface's PDU."
        }
      }
    },
    "var_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["var_ref"],
      "properties": {
        "var_ref": {
          "type": "string",
          "minLength": 1,
          "description": "A var short name (resolved as service::name) or a fully qualified service::var for cross-service references."
        }
      }
    }
  }
}
